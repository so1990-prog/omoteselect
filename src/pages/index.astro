---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="omoteselect — いぬと暮らす日々">

  <!-- Banner -->
  <div class="banner">いぬへの贈り物、送料無料</div>

  <!-- Nav -->
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <!-- Dog silhouette SVG -->
        <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M14 38 C14 38 10 35 8 28 C6 21 10 16 14 14 C16 13 18 14 20 14 C22 10 26 8 30 8 C34 8 38 10 40 14 C42 14 44 13 46 14 C50 16 54 21 52 28 C50 35 46 38 46 38 L46 50 C46 51.1 45.1 52 44 52 L38 52 C36.9 52 36 51.1 36 50 L36 46 L24 46 L24 50 C24 51.1 23.1 52 22 52 L16 52 C14.9 52 14 51.1 14 50 Z" fill="var(--accent)" opacity="0.85"/>
          <ellipse cx="22" cy="20" rx="2.5" ry="3" fill="var(--bg)" opacity="0.9"/>
          <ellipse cx="38" cy="20" rx="2.5" ry="3" fill="var(--bg)" opacity="0.9"/>
          <circle cx="22" cy="20" r="1.2" fill="var(--ink)"/>
          <circle cx="38" cy="20" r="1.2" fill="var(--ink)"/>
          <path d="M27 28 Q30 31 33 28" stroke="var(--ink)" stroke-width="1.2" fill="none" stroke-linecap="round"/>
          <ellipse cx="30" cy="26" rx="2" ry="1.5" fill="var(--ink)" opacity="0.2"/>
          <!-- Ears -->
          <path d="M14 14 C12 10 8 8 7 12 C6 16 10 16 14 14Z" fill="var(--accent)" opacity="0.7"/>
          <path d="M46 14 C48 10 52 8 53 12 C54 16 50 16 46 14Z" fill="var(--accent)" opacity="0.7"/>
          <!-- Tail -->
          <path d="M46 38 Q54 34 56 42 Q58 48 52 46" stroke="var(--accent)" stroke-width="2.5" fill="none" stroke-linecap="round" opacity="0.8"/>
        </svg>
        omoteselect
      </a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/shop">Online Shop</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/column">Column</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-text">
      <p class="hero-sub">Dog &amp; Lifestyle</p>
      <h1 class="hero-vertical">いぬと暮らす日々</h1>
      <a href="/shop" class="hero-cta">コレクションを見る</a>
    </div>
    <div class="hero-illustration">
      <!-- Hand-drawn style dog illustration -->
      <svg viewBox="0 0 500 520" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Body -->
        <ellipse cx="250" cy="320" rx="130" ry="100" fill="var(--cream)" stroke="var(--accent)" stroke-width="2.5" stroke-dasharray="6 3"/>
        <!-- Head -->
        <circle cx="250" cy="190" r="80" fill="var(--cream)" stroke="var(--accent)" stroke-width="2.5" stroke-dasharray="6 3"/>
        <!-- Left ear (floppy) -->
        <path d="M185 155 C165 130 140 130 138 158 C136 180 160 195 185 185Z" fill="#d4c4ae" stroke="var(--accent)" stroke-width="2" stroke-dasharray="5 3"/>
        <!-- Right ear (floppy) -->
        <path d="M315 155 C335 130 360 130 362 158 C364 180 340 195 315 185Z" fill="#d4c4ae" stroke="var(--accent)" stroke-width="2" stroke-dasharray="5 3"/>
        <!-- Eyes -->
        <circle cx="220" cy="185" r="12" fill="var(--ink)" opacity="0.85"/>
        <circle cx="280" cy="185" r="12" fill="var(--ink)" opacity="0.85"/>
        <circle cx="215" cy="181" r="4" fill="#fff" opacity="0.7"/>
        <circle cx="275" cy="181" r="4" fill="#fff" opacity="0.7"/>
        <!-- Nose -->
        <ellipse cx="250" cy="210" rx="12" ry="9" fill="var(--ink)" opacity="0.75"/>
        <circle cx="246" cy="207" r="3" fill="#fff" opacity="0.5"/>
        <!-- Mouth -->
        <path d="M238 222 Q250 234 262 222" stroke="var(--ink)" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.7"/>
        <!-- Front legs -->
        <rect x="175" y="390" width="40" height="90" rx="20" fill="var(--cream)" stroke="var(--accent)" stroke-width="2" stroke-dasharray="5 3"/>
        <rect x="285" y="390" width="40" height="90" rx="20" fill="var(--cream)" stroke="var(--accent)" stroke-width="2" stroke-dasharray="5 3"/>
        <!-- Paws -->
        <ellipse cx="195" cy="485" rx="24" ry="12" fill="#d4c4ae" stroke="var(--accent)" stroke-width="1.5"/>
        <ellipse cx="305" cy="485" rx="24" ry="12" fill="#d4c4ae" stroke="var(--accent)" stroke-width="1.5"/>
        <!-- Tail -->
        <path d="M375 300 Q420 260 430 300 Q440 340 400 350 Q380 355 370 340" stroke="var(--accent)" stroke-width="3" fill="none" stroke-linecap="round" stroke-dasharray="7 4"/>
        <!-- Collar -->
        <path d="M195 260 Q250 275 305 260" stroke="var(--accent)" stroke-width="4" fill="none" stroke-linecap="round"/>
        <circle cx="250" cy="270" r="8" fill="var(--accent)" opacity="0.6"/>
        <!-- Spot decoration -->
        <ellipse cx="220" cy="330" rx="25" ry="18" fill="var(--accent)" opacity="0.12"/>
        <ellipse cx="290" cy="310" rx="18" ry="14" fill="var(--accent)" opacity="0.1"/>
      </svg>
    </div>
  </section>

  <!-- Concept -->
  <section class="concept">
    <div>
      <h2 class="concept-heading">
        いぬがいる暮らしを、<br/>
        もっと<span>豊か</span>に。
      </h2>
    </div>
    <div class="concept-body">
      <p>
        omoteselect は、いぬとともに暮らす人々のために選りすぐったライフスタイルアイテムをお届けするセレクトショップです。
      </p>
      <p>
        リネン、陶器、ウール、真鍮——自然素材がもつ静かな美しさと、長く使えるたしかな品質。毎日の散歩も、食事も、眠りも、少しだけ特別な時間になるように。
      </p>
      <p>
        いぬとの日々を、もっとていねいに。
      </p>
    </div>
  </section>

  <!-- Products -->
  <section class="products">
    <div class="products-inner">
      <div class="section-header">
        <p class="section-label">Featured Items</p>
        <h2 class="section-title">おすすめアイテム</h2>
      </div>
      <div class="products-grid">

        <!-- Product 1: リネンハーネス -->
        <div class="product-card">
          <div class="product-img">
            <svg viewBox="0 0 200 240" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Harness illustration -->
              <rect x="60" y="80" width="80" height="40" rx="8" fill="none" stroke="var(--accent)" stroke-width="3" stroke-dasharray="6 3"/>
              <path d="M100 80 L100 50 M100 50 Q100 35 115 35 L130 35 Q145 35 145 50 L145 80" stroke="var(--accent)" stroke-width="3" fill="none" stroke-linecap="round"/>
              <path d="M100 120 L100 150 M100 150 Q100 165 85 165 L70 165 Q55 165 55 150 L55 120" stroke="var(--accent)" stroke-width="3" fill="none" stroke-linecap="round"/>
              <circle cx="100" cy="100" r="8" fill="var(--accent)" opacity="0.3"/>
              <circle cx="100" cy="100" r="4" fill="var(--accent)" opacity="0.6"/>
            </svg>
          </div>
          <div class="product-info">
            <span class="product-tag">LINEN</span>
            <p class="product-name">リネンハーネス</p>
            <p class="product-price">¥4,800</p>
          </div>
        </div>

        <!-- Product 2: 陶器ウォーターボウル -->
        <div class="product-card">
          <div class="product-img">
            <svg viewBox="0 0 200 240" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Bowl illustration -->
              <path d="M55 130 Q55 185 100 185 Q145 185 145 130Z" fill="var(--cream)" stroke="var(--accent)" stroke-width="2.5" stroke-dasharray="5 3"/>
              <ellipse cx="100" cy="130" rx="45" ry="16" fill="none" stroke="var(--accent)" stroke-width="2.5"/>
              <ellipse cx="100" cy="130" rx="35" ry="11" fill="rgba(184,131,74,0.1)"/>
              <!-- Water effect -->
              <path d="M72 155 Q85 150 100 155 Q115 160 128 155" stroke="#7ab4c8" stroke-width="1.5" fill="none" opacity="0.6" stroke-linecap="round"/>
              <path d="M68 165 Q85 160 100 165 Q115 170 132 165" stroke="#7ab4c8" stroke-width="1.5" fill="none" opacity="0.4" stroke-linecap="round"/>
              <!-- Base -->
              <rect x="85" y="185" width="30" height="8" rx="4" fill="var(--accent)" opacity="0.3"/>
              <rect x="75" y="193" width="50" height="5" rx="2.5" fill="var(--accent)" opacity="0.2"/>
            </svg>
          </div>
          <div class="product-info">
            <span class="product-tag">CERAMIC</span>
            <p class="product-name">陶器ウォーターボウル</p>
            <p class="product-price">¥3,200</p>
          </div>
        </div>

        <!-- Product 3: ウールクッションベッド -->
        <div class="product-card">
          <div class="product-img">
            <svg viewBox="0 0 200 240" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Cushion bed illustration -->
              <path d="M40 160 Q40 110 100 105 Q160 100 165 155 L165 175 Q165 195 100 195 Q40 195 40 175Z" fill="var(--cream)" stroke="var(--accent)" stroke-width="2.5" stroke-dasharray="6 3"/>
              <!-- Cushion lines -->
              <path d="M65 140 Q100 135 135 140" stroke="var(--accent)" stroke-width="1.5" fill="none" opacity="0.4" stroke-dasharray="4 3"/>
              <path d="M55 155 Q100 150 145 155" stroke="var(--accent)" stroke-width="1.5" fill="none" opacity="0.4" stroke-dasharray="4 3"/>
              <path d="M55 170 Q100 165 145 170" stroke="var(--accent)" stroke-width="1.5" fill="none" opacity="0.4" stroke-dasharray="4 3"/>
              <!-- Border roll -->
              <ellipse cx="100" cy="107" rx="60" ry="22" fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-dasharray="6 3"/>
              <ellipse cx="100" cy="107" rx="45" ry="16" fill="rgba(184,131,74,0.08)"/>
            </svg>
          </div>
          <div class="product-info">
            <span class="product-tag">WOOL</span>
            <p class="product-name">ウールクッションベッド</p>
            <p class="product-price">¥12,800</p>
          </div>
        </div>

        <!-- Product 4: 真鍮ネームプレート -->
        <div class="product-card">
          <div class="product-img">
            <svg viewBox="0 0 200 240" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Name plate illustration -->
              <rect x="55" y="105" width="90" height="55" rx="10" fill="#d4a85a" opacity="0.25" stroke="var(--accent)" stroke-width="2.5"/>
              <rect x="60" y="110" width="80" height="45" rx="8" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-dasharray="4 3" opacity="0.5"/>
              <!-- Text lines representing engraving -->
              <path d="M75 127 L125 127" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
              <path d="M82 140 L118 140" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
              <!-- Ring at top -->
              <circle cx="100" cy="98" r="10" fill="none" stroke="var(--accent)" stroke-width="2.5"/>
              <circle cx="100" cy="98" r="5" fill="rgba(184,131,74,0.3)"/>
              <!-- Chain links -->
              <path d="M100 88 L100 80" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"/>
              <ellipse cx="100" cy="75" rx="8" ry="5" fill="none" stroke="var(--accent)" stroke-width="2" transform="rotate(-30 100 75)"/>
              <ellipse cx="100" cy="65" rx="8" ry="5" fill="none" stroke="var(--accent)" stroke-width="2" transform="rotate(30 100 65)"/>
            </svg>
          </div>
          <div class="product-info">
            <span class="product-tag">BRASS</span>
            <p class="product-name">真鍮ネームプレート</p>
            <p class="product-price">¥2,400</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- News -->
  <section class="news">
    <div class="news-inner">
      <div class="section-header">
        <p class="section-label">Latest News</p>
        <h2 class="section-title">お知らせ</h2>
      </div>
      <div class="news-list">
        <div class="news-item">
          <span class="news-date">2026.04.10</span>
          <span class="news-cat">NEW</span>
          <span>春のリネンコレクション、入荷しました。</span>
        </div>
        <div class="news-item">
          <span class="news-date">2026.03.28</span>
          <span class="news-cat">COLUMN</span>
          <span>いぬとのお散歩を、もっと快適に——ハーネスの選び方。</span>
        </div>
        <div class="news-item">
          <span class="news-date">2026.03.15</span>
          <span class="news-cat">INFO</span>
          <span>ゴールデンウィーク期間中の発送スケジュールについて。</span>
        </div>
        <div class="news-item">
          <span class="news-date">2026.02.20</span>
          <span class="news-cat">COLUMN</span>
          <span>陶器ボウルのお手入れ方法と長く使うためのヒント。</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-inner">
      <div>
        <div class="footer-brand">
          <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M14 38 C14 38 10 35 8 28 C6 21 10 16 14 14 C16 13 18 14 20 14 C22 10 26 8 30 8 C34 8 38 10 40 14 C42 14 44 13 46 14 C50 16 54 21 52 28 C50 35 46 38 46 38 L46 50 C46 51.1 45.1 52 44 52 L38 52 C36.9 52 36 51.1 36 50 L36 46 L24 46 L24 50 C24 51.1 23.1 52 22 52 L16 52 C14.9 52 14 51.1 14 50 Z" fill="rgba(255,255,255,0.6)"/>
            <path d="M14 14 C12 10 8 8 7 12 C6 16 10 16 14 14Z" fill="rgba(255,255,255,0.4)"/>
            <path d="M46 14 C48 10 52 8 53 12 C54 16 50 16 46 14Z" fill="rgba(255,255,255,0.4)"/>
          </svg>
          omoteselect
        </div>
        <p class="footer-desc">
          いぬと暮らす人々のための<br/>
          ライフスタイルセレクトショップ。<br/>
          自然素材にこだわった上質なアイテムをお届けします。
        </p>
      </div>
      <div>
        <p class="footer-col-title">Shop</p>
        <ul class="footer-links">
          <li><a href="/shop">すべての商品</a></li>
          <li><a href="/shop/harness">ハーネス・リード</a></li>
          <li><a href="/shop/bowl">ボウル・食器</a></li>
          <li><a href="/shop/bed">ベッド・クッション</a></li>
          <li><a href="/shop/accessories">アクセサリー</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-title">Info</p>
        <ul class="footer-links">
          <li><a href="/about">About</a></li>
          <li><a href="/column">Column</a></li>
          <li><a href="/faq">よくある質問</a></li>
          <li><a href="/shipping">送料・配送</a></li>
          <li><a href="/contact">お問い合わせ</a></li>
        </ul>
      </div>
      <div>
        <p class="footer-col-title">Legal</p>
        <ul class="footer-links">
          <li><a href="/privacy">プライバシーポリシー</a></li>
          <li><a href="/terms">利用規約</a></li>
          <li><a href="/tokushoho">特定商取引法</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 omoteselect. All rights reserved.</p>
    </div>
  </footer>

</BaseLayout>
